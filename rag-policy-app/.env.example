# ─── TechCorp Policy RAG — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ── Required ────────────────────────────────────────────────────────────────────
# Get your FREE Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false
